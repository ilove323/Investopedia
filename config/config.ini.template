# =====================================================
# 政策库知识库+知识图谱系统 - 配置文件模板
# =====================================================
# 说明：复制此文件为 config.ini，然后根据实际情况修改

[APP]
# 应用名称
name = 政策库知识库+知识图谱系统
description = 专项债、特许经营、数据资产政策知识库
icon = 📋
layout = wide
debug = false

# 默认语言
default_language = zh
supported_languages = zh,en

# 搜索配置
search_results_per_page = 10
max_search_results = 100

# 知识图谱配置
graph_max_nodes = 200
graph_max_edges = 500
default_graph_layout = force_directed

# 时效性检查配置
expiration_warning_days = 30

# 文件上传配置（字节）
max_upload_size = 52428800  # 50MB
allowed_file_types = pdf,docx,xlsx,txt

# 大模型提供商选择：qwen 或 openai
provider = qwen
# 实体提取提示词文件路径
entity_prompt_file = config/prompts/entity_extraction.txt

# =====================================================
[RAGFLOW]
# RAGFlow服务地址
host = localhost
port = 9380

# RAGFlow API认证
# 说明：使用API Key进行请求认证，通过HTTP Authorization头发送
# 格式：api_key = your-api-key-here
# 设置为空字符串表示无认证（公开访问）
api_key =

# API超时和重试配置
timeout = 30
retry_times = 3
retry_delay = 1

# 搜索配置
search_top_k = 10
search_score_threshold = 0.5
search_type = hybrid

# 问答配置
qa_max_tokens = 2000
qa_temperature = 0.1
qa_top_p = 0.9

# 文档处理配置
# 政策条目较长，使用较大的分块大小
document_chunk_size = 800
# 增加重叠保持连贯性
document_chunk_overlap = 100
document_smart_chunking = true

# RAGFlow知识库高级配置
# 最大TOKEN数
ragflow_max_tokens = 2048
# 相似度阈值（检索召回）
ragflow_similarity_threshold = 0.3
# 最大聚类数
ragflow_max_clusters = 50
# 随机种子
ragflow_random_seed = 42

# RAGFlow元数据和文档解析配置
# 自动元数据提取
ragflow_auto_metadata = true
# 元数据提取（结构化信息）
ragflow_metadata_extraction = true
# 表格识别
ragflow_table_recognition = true
# 公式识别
ragflow_formula_recognition = false
# OCR识别
ragflow_ocr_enabled = true
# PDF解析器
ragflow_pdf_parser = deepdoc
# 检索模式
ragflow_retrieval_mode = general
# 实体归一化
ragflow_entity_normalization = true
# 图检索增强
ragflow_graph_retrieval = true

# ========== 知识库配置 ==========
# 说明：以下知识库需要在RAGFlow中手动创建
#
# 前置步骤：
# 1. 访问 RAGFlow Web界面：http://host:port
# 2. 登录RAGFlow管理后台
# 3. 创建知识库（Knowledge Base）
# 4. 设置知识库名称为下面配置的 kb_name 值
#
# 知识库名称（必须与RAGFlow中创建的知识库名称一致）
kb_name = policy_demo_kb

# 知识库描述
kb_description = 政策知识库 - 专项债/特许经营/数据资产

# 日志级别
log_level = INFO

# =====================================================

[WHISPER]
# Whisper服务地址
host = localhost
port = 9000

# API超时和重试配置
timeout = 60
retry_times = 3
retry_delay = 1

# 转写配置
transcribe_task = transcribe
transcribe_language = zh
word_timestamps = false

# 音频处理配置
audio_sample_rate = 16000
audio_channels = 1
audio_normalize = true
audio_remove_silence = false
audio_max_duration = 300  # 秒，5分钟

# 文件配置
audio_max_file_size = 52428800  # 50MB
audio_supported_formats = .wav,.mp3,.m4a,.flac,.ogg

# 模型配置
whisper_model = base  # tiny/base/small/medium/large
whisper_device = cpu  # cpu/gpu
whisper_compute_type = float32

# 日志级别
log_level = INFO

# =====================================================
[DATABASE]
# 数据库类型
type = sqlite

# SQLite配置
sqlite_path = data/database/policy.db
sqlite_check_same_thread = false
sqlite_timeout = 10.0

# 连接池配置
pool_size = 5
max_overflow = 10
pool_recycle = 3600

# 初始化配置
auto_create_tables = true
auto_init_tags = true

# 查询配置
query_timeout = 30
batch_size = 100

# 日志级别
log_level = INFO
sql_echo = false

# =====================================================
[GRAPH]
# 图谱渲染存储路径
graph_storage_dir = data/graphs

# 图谱配置
is_directed = false
graph_type = undirected

# Pyvis可视化配置
pyvis_height = 750px
pyvis_width = 100%
pyvis_bgcolor = #222222
pyvis_font_color = white
pyvis_font_size = 14
pyvis_physics_enabled = true
pyvis_stabilization_iterations = 200

# 图谱限制
max_nodes = 200
max_edges = 500
max_node_label_length = 20

# 渲染配置
save_html = true
export_formats = html,json,svg
auto_refresh = false

# 默认视图
default_view = 全局视图

# 日志级别
log_level = INFO

# =====================================================
[LOGGING]
# 日志输出配置
log_dir = logs
log_level = INFO
log_format = %(asctime)s - %(name)s - %(levelname)s - %(message)s

# 日志轮转配置
rotating_max_bytes = 10485760  # 10MB
rotating_backup_count = 5

# =====================================================
[QWEN]
# 阿里云通义千问大模型配置
# API密钥获取地址: https://dashscope.console.aliyun.com/

# API密钥（必填）
api_key = your-dashscope-api-key-here

# 模型选择
# qwen-turbo: 快速响应，适合简单任务
# qwen-plus: 平衡性能，推荐使用
# qwen-max: 最强性能，复杂任务
model = qwen-plus

# 生成参数
temperature = 0.1  # 温度参数 (0-1)，越低越确定
max_tokens = 8000  # 最大生成token数

# =====================================================
[OPENAI]
# OpenAI 兑容接口配置（支持任意兑容 OpenAI 协议的模型服务）
# 接入地址（必填），例如:
#   OpenAI 官方:  https://api.openai.com/v1
#   本地 Ollama:  http://localhost:11434/v1
#   其他代理服务: http://your-proxy/v1
base_url = https://api.openai.com/v1
api_key = your-api-key-here
model = gpt-4o-mini
temperature = 0.1  # 温度参数 (0-1)，越低越确定
max_tokens = 8000   # 最大生成token数
